// ---------------------------------------------------------
// GENERATOR & DATASOURCE PARA SUPABASE
//
// IMPORTANTE: Prisma Client NO se usa en runtime.
// Este schema cumple dos únicas funciones:
//   1. Generar tipos TypeScript (via `prisma generate`) usados solo
//      como `import type` en el código — cero impacto en bundle.
//   2. Gestionar migraciones SQL (via `prisma migrate` / CLI).
// Todas las queries en producción se realizan con @supabase/supabase-js.
// ---------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// ENUMS (Sistema de D&D y Permisos)
// ---------------------------------------------------------
enum Rarity {
  JUNK
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  ARTIFACT
}

enum ResourceType {
  MONSTER_TEMPLATE
  ITEM_TEMPLATE
  CHARACTER_TEMPLATE
  CAMPAIGN
}

enum AccessType {
  VIEW
  EDIT
}

// ---------------------------------------------------------
// 1. USUARIOS (Conectados con Clerk)
// ---------------------------------------------------------
model User {
  id      String  @id @default(cuid())
  clerkId String  @unique
  email   String  @unique
  name    String?
  image   String?
  plan    String  @default("FREE")

  campaigns        Campaign[]
  createdCharacterTemplates CharacterTemplate[] @relation("CreatedCharacterTemplates")
  playerCharacters Character[]         @relation("PlayerCharacters")
  createdMonsters  MonsterTemplate[]   @relation("CreatedMonsters")
  createdItems     ItemTemplate[]      @relation("CreatedItems")
  
  accessGrants     AccessGrant[]       @relation("UserAccess")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------
// 2. CAMPAÑA (La Mesa con el Portal de Piedra)
// ---------------------------------------------------------
model Campaign {
  id               String  @id @default(cuid())
  name             String
  description      String?
  imageUrl         String?
  system           String  @default("D&D 5e")
  location         String?
  nextSession      DateTime?
  isPrivate        Boolean @default(true)
  parentCampaignId String?

  gameMasterId String
  gameMaster   User   @relation(fields: [gameMasterId], references: [id], onDelete: Cascade)

  characters     Character[]
  notes          SessionNote[]
  activeMonsters ActiveMonster[]
  quests         Quest[]
  items          Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------
// 3. PLANTILLA DE PERSONAJE (El "Molde" para el Market)
// ---------------------------------------------------------
model CharacterTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  portraitImageUrl String?

  race           String @default("Desconocido")
  characterClass String @default("Desconocido")
  maxHp          Int    @default(8)
  abilities      Json?

  // Stats Atómicos
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)
  ac           Int @default(10)
  speed        Int @default(30)
  initiativeBonus Int @default(0)
  perception   Int @default(10)

  authorId String?
  author   User?   @relation("CreatedCharacterTemplates", fields: [authorId], references: [id], onDelete: SetNull)

  isPublished Boolean @default(false)
  version     Int     @default(1)
  price       Float   @default(0.0)

  instances Character[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strength])
  @@index([dexterity])
  @@index([ac])
}

// ---------------------------------------------------------
// 4. PERSONAJE (La Instancia Viva que juega)
// ---------------------------------------------------------
model Character {
  id   String @id @default(cuid())
  name String

  userId String?
  user   User?   @relation("PlayerCharacters", fields: [userId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  templateId String?
  template   CharacterTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  imageUrl         String?
  portraitImageUrl String?

  level     Int    @default(1)
  currentHp Int
  maxHp     Int
  tempHp    Int    @default(0)

  // Stats Atómicos
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)
  ac           Int @default(10)
  speed        Int @default(30)
  initiativeBonus Int @default(0)
  perception   Int @default(10)

  inventory Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([campaignId])
}

// ---------------------------------------------------------
// 5. PLANTILLA DE ÍTEM (El Molde)
// ---------------------------------------------------------
model ItemTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  
  category    String  @default("General")
  weight      Float   @default(0.0)
  value       Int     @default(0)
  rarity      Rarity  @default(COMMON)
  isPublic    Boolean @default(false)

  // Modificadores Atómicos
  strength     Int @default(0)
  dexterity    Int @default(0)
  constitution Int @default(0)
  intelligence Int @default(0)
  wisdom       Int @default(0)
  charisma     Int @default(0)
  ac           Int @default(0)
  speed        Int @default(0)
  initiativeBonus Int @default(0)
  perception   Int @default(0)

  creatorId String?
  creator   User?   @relation("CreatedItems", fields: [creatorId], references: [id], onDelete: SetNull)

  instances Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rarity])
  @@index([category])
}

// ---------------------------------------------------------
// 6. ÍTEM (Instancia en el mundo o inventario)
// ---------------------------------------------------------
model Item {
  id          String  @id @default(cuid())
  name        String
  description String?
  imageUrl    String?

  quantity    Int     @default(1)
  rarity      Rarity  @default(COMMON)
  isEquipped  Boolean @default(false)
  isAttuned   Boolean @default(false)
  notes       String?

  // Modificadores Atómicos (pueden diferir de la plantilla)
  strength     Int @default(0)
  dexterity    Int @default(0)
  constitution Int @default(0)
  intelligence Int @default(0)
  wisdom       Int @default(0)
  charisma     Int @default(0)
  ac           Int @default(0)
  speed        Int @default(0)
  initiativeBonus Int @default(0)
  perception   Int @default(0)

  templateId String?
  template   ItemTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([characterId])
}

// ---------------------------------------------------------
// 7. NOTAS DE SESIÓN
// ---------------------------------------------------------
model SessionNote {
  id         String   @id @default(cuid())
  title      String?
  content    String   @db.Text
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ---------------------------------------------------------
// 8. PLANTILLA DE MONSTRUO (Bestiario)
// ---------------------------------------------------------
model MonsterTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  type        String
  race           String @default("Desconocido")
  characterClass String @default("Desconocido")
  imageUrl         String?
  portraitImageUrl String?

  challenge Float @default(1.0)
  maxHp     Int
  
  // Stats Atómicos
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)
  ac           Int @default(10)
  speed        Int @default(30)
  initiativeBonus Int @default(0)
  perception   Int @default(10)

  abilities Json? 

  authorId String?
  author   User?   @relation("CreatedMonsters", fields: [authorId], references: [id], onDelete: SetNull)

  isPublished Boolean @default(false)
  price       Float   @default(0.0)
  version     Int     @default(1)

  instances ActiveMonster[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([challenge])
  @@index([type])
}

// ---------------------------------------------------------
// 9. MONSTRUO ACTIVO (Instancia de Combate)
// ---------------------------------------------------------
model ActiveMonster {
  id         String   @id @default(cuid())
  name       String? 
  currentHp  Int
  maxHp      Int 
  initiative Int?
  status     String[] 
  imageUrl         String?
  portraitImageUrl String?

  // Stats Atómicos (Override opcional)
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)
  ac           Int @default(10)
  speed        Int @default(30)
  initiativeBonus Int @default(0)
  perception   Int @default(10)

  templateId String?
  template   MonsterTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
}

// ---------------------------------------------------------
// 10. MISIONES (Quests)
// ---------------------------------------------------------
model Quest {
  id               String   @id @default(cuid())
  title            String
  description      String?  @db.Text
  isCompleted      Boolean  @default(false)
  visibleToPlayers Boolean  @default(false)
  priority         String   @default("NORMAL")

  campaignId       String
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------
// 11. PERMISOS (Access Control)
// ---------------------------------------------------------
model AccessGrant {
  id           String       @id @default(cuid())
  granteeId    String
  grantee      User         @relation("UserAccess", fields: [granteeId], references: [id], onDelete: Cascade)
  
  resourceType ResourceType
  resourceId   String
  access       AccessType   @default(VIEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([granteeId])
  @@index([resourceId])
}
