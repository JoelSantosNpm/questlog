
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// datasource y client configurados para Supabase

// 1. User Table (Clerk Integration)
model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  name      String?
  image     String?    // User avatar
  
  campaigns Campaign[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?  // Cover image for the campaign
  
  // Relation to User (DM)
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // El Cronicón: Notas de sesión
  notes       SessionNote[]

  // El Almacén: Inventario vinculado a la campaña
  items       Item[]

  // El Coliseo: Monstruos que están actualmente en la "mesa"
  activeEnemies ActiveMonster[]
}

model SessionNote {
  id         String   @id @default(cuid())
  content    String   @db.Text
  createdAt  DateTime @default(now())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
}

model Monster {
  id           String   @id @default(cuid())
  name         String
  type         String   // Ej: Dragon, Undead
  challenge    Float    // CR (Nivel de desafío)
  maxHp        Int
  ac           Int      // Clase de Armadura
  stats        Json     // Fuerza, Destreza, etc.
  abilities    Json?    // Habilidades especiales
  
  // Relación para saber en qué campañas "podría" aparecer
  instances    ActiveMonster[]
}

model ActiveMonster {
  id         String   @id @default(cuid())
  name       String?  // Optional override name (e.g. "Goblin Boss")
  currentHp  Int
  maxHp      Int?     // Copied from base to allow unique max HP
  initiative Int?
  status     String[] // ["Poisoned", "Stunned"]
  
  // Link to base definition
  monsterId  String
  monster    Monster  @relation(fields: [monsterId], references: [id])
  
  // Link to Campaign context (The "Active" session state)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  createdAt  DateTime @default(now())
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  
  // Core RPG Stats
  rarity      String   // Common, Rare, Legendary...
  type        String   // Weapon, Potion, Gear
  weight      Float?   // in lbs
  value       Float?   // in Gold Pieces (gp)
  image       String?  // Item icon/image URL
  
  // State
  quantity    Int      @default(1)
  equipped    Boolean  @default(false)
  attuned     Boolean  @default(false)
  notes       String?  // Custom player notes
  
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
}