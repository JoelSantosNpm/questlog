
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// datasource y client configurados para Supabase

// 1. User Table (Clerk Integration)
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  image     String? // User avatar cache

  // Un usuario puede ser DM de muchas campañas
  campaigns  Campaign[]
  // Un usuario puede tener muchos personajes en distintas campañas
  characters Character[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Campaign (La mesa de juego)
model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?

  // El Master (DM)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relaciones de la mesa
  characters     Character[] // Los aventureros en esta mesa
  notes          SessionNote[] // El Cronicón
  activeEnemies  ActiveMonster[] // El Coliseo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3. Character (El aventurero)
model Character {
  id   String @id @default(cuid())
  name String
  
  // Relación con el Jugador (User)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relación con la Campaña
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  // El Almacén: Inventario propio del personaje
  inventory Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. Item (Objetos del inventario)
model Item {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Stats
  rarity   String // Common, Rare, Legendary...
  type     String // Weapon, Potion, Gear
  weight   Float? // in lbs
  value    Float? // in Gold Pieces (gp)
  image    String?
  quantity Int     @default(1)
  
  // State
  equipped Boolean @default(false)
  attuned  Boolean @default(false)
  notes    String?

  // El ítem pertenece a un personaje
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
}

// 5. SessionNote (El Cronicón)
model SessionNote {
  id         String   @id @default(cuid())
  content    String   @db.Text
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  createdAt  DateTime @default(now())
}

// 6. Monster (Definición base)
model Monster {
  id        String @id @default(cuid())
  name      String
  type      String
  challenge Float
  maxHp     Int
  ac        Int
  stats     Json
  abilities Json?

  instances ActiveMonster[]
}

// 7. ActiveMonster (En combate)
model ActiveMonster {
  id         String   @id @default(cuid())
  name       String?
  currentHp  Int
  maxHp      Int?
  initiative Int?
  status     String[]

  monsterId String
  monster   Monster @relation(fields: [monsterId], references: [id])

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
}

