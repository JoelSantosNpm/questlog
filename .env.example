# -----------------------------------------------------------------------------
# QUESTLOG - ARCHIVO DE CONFIGURACIÓN DE DESARROLLO (.env.example)
# Copia este archivo como .env y rellena los valores con tus propias keys.
# -----------------------------------------------------------------------------

# CLERK (Autenticación y Sesiones)
# Consíguelas en: Dashboard > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# SUPABASE (Base de Datos y Storage)
# Consíguelas en: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PRISMA (Conexión a Base de Datos)
# URL de conexión (Pooler)
DATABASE_URL_LOCAL="postgresql://user:password@localhost:5432/questlog"
DATABASE_URL_REMOTE="postgresql://postgres:[password]@db.[id].supabase.co:6543/postgres?pgbouncer=true"
# URL directa (Migraciones)
DIRECT_URL="postgresql://postgres:[password]@db.[id].supabase.co:5432/postgres"

# CLERK WEBHOOKS (Sincronización Clerk -> Prisma)
# Consíguela en: Dashboard > Webhooks > Tu Webhook > Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# SCRIPTS Y SEED (Datos de prueba)
# Correos de prueba para el script prisma/seed.ts
SEED_USER_EMAIL=user@example.com
SEED_GM_EMAIL=gm@example.com
SEED_PLAYER_EMAIL=player@example.com

# TESTING (Pruebas E2E con Playwright)
# Usuario para los tests automatizados
E2E_CLERK_USER_EMAIL=test-user@example.com
